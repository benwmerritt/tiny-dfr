#!/usr/bin/env bash
set -euo pipefail

if [[ "${SKIP_RUST_HOOKS:-}" == "1" ]]; then
  echo "Skipping Rust pre-commit checks because SKIP_RUST_HOOKS=1" >&2
  exit 0
fi

if ! command -v cargo >/dev/null 2>&1 && [[ -f "$HOME/.cargo/env" ]]; then
  # Git hooks often run with a narrower PATH than an interactive shell.
  # Source rustup's environment file when available so user-space Rust works.
  # shellcheck disable=SC1091
  source "$HOME/.cargo/env"
fi

if ! command -v cargo >/dev/null 2>&1; then
  cat >&2 <<'MSG'
Rust toolchain not found: cargo is not on PATH.
Install Rust or run this commit with SKIP_RUST_HOOKS=1 if you are only changing docs/bootstrap files.
MSG
  exit 1
fi

echo "Running cargo fmt --check"
cargo fmt --check

echo "Running cargo clippy -- -D warnings"
cargo clippy -- -D warnings

echo "Running cargo test"
cargo test
